# ============================================================
# NexaCommerce — Environment Variables Template
# Copy to .env.local and fill in your values
# NEVER commit .env.local to git
# ============================================================

# ── Application ──────────────────────────────────────────────
NEXACOMMERCE_ENV=development
LOG_LEVEL=debug
APP_VERSION=local

# ── Database (PostgreSQL) ────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=nexacommerce
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=nexacommerce

# Per-service DB URLs (override above)
AUTH_DATABASE_URL=postgres://nexacommerce:change-me@localhost:5432/auth_db
PRODUCT_DATABASE_URL=postgres://nexacommerce:change-me@localhost:5432/product_db
ORDER_DATABASE_URL=postgres://nexacommerce:change-me@localhost:5432/order_db
PAYMENT_DATABASE_URL=postgres://nexacommerce:change-me@localhost:5432/payment_db
INVENTORY_DATABASE_URL=postgres://nexacommerce:change-me@localhost:5432/inventory_db

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change-me-in-production
REDIS_URL=redis://:change-me@localhost:6379

# ── Kafka ────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:29092
KAFKA_GROUP_ID=nexacommerce-local
KAFKA_AUTO_OFFSET_RESET=earliest

# ── MongoDB ──────────────────────────────────────────────────
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_USER=nexacommerce
MONGO_PASSWORD=change-me-in-production
MONGODB_URI=mongodb://nexacommerce:change-me@localhost:27017/nexacommerce

# ── Elasticsearch ────────────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=change-me-in-production

# ── JWT / Auth ───────────────────────────────────────────────
JWT_SECRET=super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d
JWT_ISSUER=nexacommerce-auth
JWT_AUDIENCE=nexacommerce-api

# OAuth2 Providers
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# ── Payment (Stripe) ─────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your-stripe-test-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key

# ── Email (SMTP) ─────────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@nexacommerce.local
SMTP_TLS=false

# ── AWS ──────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_DEFAULT_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012

# S3
S3_BUCKET_ASSETS=nexacommerce-assets-dev
S3_BUCKET_BACKUPS=nexacommerce-backups-dev
S3_REGION=us-east-1

# ECR
ECR_REGISTRY=123456789012.dkr.ecr.us-east-1.amazonaws.com

# ── Azure ────────────────────────────────────────────────────
ARM_SUBSCRIPTION_ID=your-subscription-id
ARM_TENANT_ID=your-tenant-id
ARM_CLIENT_ID=your-client-id
ARM_CLIENT_SECRET=your-client-secret
AZURE_RESOURCE_GROUP=nexacommerce-dev-rg
AZURE_LOCATION=westeurope

# ── GCP ──────────────────────────────────────────────────────
GOOGLE_PROJECT=your-gcp-project-id
GOOGLE_REGION=us-central1
GOOGLE_CREDENTIALS=/path/to/service-account.json

# ── Kubernetes ───────────────────────────────────────────────
KUBECONFIG=~/.kube/config
K8S_NAMESPACE=nexacommerce-dev
CLUSTER_NAME=nexacommerce-dev

# ── Terraform ────────────────────────────────────────────────
TF_VAR_environment=dev
TF_VAR_project=nexacommerce
TF_VAR_aws_region=us-east-1
TF_STATE_BUCKET=nexacommerce-tf-state
TF_STATE_KEY=dev/terraform.tfstate

# ── Monitoring ───────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_URL=http://localhost:3001
PROMETHEUS_URL=http://localhost:9090

# ── ArgoCD ───────────────────────────────────────────────────
ARGOCD_SERVER=localhost:8888
ARGOCD_USERNAME=admin
ARGOCD_PASSWORD=change-me-in-production

# ── HashiCorp Vault ──────────────────────────────────────────
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=root
VAULT_NAMESPACE=

# ── Feature Flags ────────────────────────────────────────────
FEATURE_RECOMMENDATIONS=true
FEATURE_SEARCH_V2=false
FEATURE_PAYMENT_APPLE_PAY=false
FEATURE_DARK_MODE=true

# ── Frontend ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_ENV=development
NEXT_PUBLIC_STRIPE_KEY=pk_test_your-publishable-key
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
